#!/bin/bash

# Set database credentials
DB_USER=${DKA_ROOT_USERNAME:-root}
# Set default values if environment variables are not provided
ROOT_PASSWORD=${DKA_ROOT_PASSWORD:-root}
BACKUP_DIR="/backup"
# shellcheck disable=SC1001
DATE=$(date +\%d-\%m-\%Y_\%H-\%M-\%S)
BACKUP_FILE="$BACKUP_DIR/all_databases_$DATE.sql.gz"

# Optional S3/Wasabi upload settings
DKA_S3_UPLOAD_ENABLE=${DKA_S3_UPLOAD_ENABLE:-false}
DKA_S3_BUCKET=${DKA_S3_BUCKET:-}
DKA_S3_PATH=${DKA_S3_PATH:-/}
DKA_S3_ENDPOINT=${DKA_S3_ENDPOINT:-https://s3.ap-southeast-1.wasabisys.com}
DKA_S3_REGION=${DKA_S3_REGION:-ap-southeast-1}

# Create a backup directory if it doesn't exist
mkdir -p $BACKUP_DIR
echo "Backing up all databases..."
# Create a backup of all databases and compress it into a .sql.gz file using mariadb tools
ESCAPED_ROOT_PASSWORD=$(printf '%s' "$ROOT_PASSWORD" | sed 's/[&/]/\\&/g')
mariadb-dump -u $DB_USER -p"$ESCAPED_ROOT_PASSWORD" --all-databases --lock-all-tables --add-drop-table --routines --triggers --events --verbose --force | gzip -9 > "$BACKUP_FILE"

if [ $? -eq 0 ]; then
    echo "Backup completed successfully: $BACKUP_FILE"
    
    # Housekeeping: delete local backups older than 30 days
    find "$BACKUP_DIR" -name "*.sql.gz" -type f -mtime +30 -delete
    echo "🧹 Housekeeping selesai (backup >30 hari dihapus)."
else
    echo "Backup failed."
    rm -f "$BACKUP_FILE"
    exit 1
fi

# Jika upload diaktifkan, kirim file ke S3/Wasabi menggunakan aws CLI
if [ "$DKA_S3_UPLOAD_ENABLE" = "true" ]; then
    if [ -z "$DKA_S3_BUCKET" ]; then
        echo "S3 upload enabled but DKA_S3_BUCKET is not set. Skipping upload."
    else
        UPLOAD_TARGET="s3://$DKA_S3_BUCKET"
        if [ -n "$DKA_S3_PATH" ] && [ "$DKA_S3_PATH" != "/" ]; then
            UPLOAD_TARGET="$UPLOAD_TARGET/${DKA_S3_PATH#/}"
        fi

        if command -v aws >/dev/null 2>&1; then
            echo "Uploading $BACKUP_FILE -> $UPLOAD_TARGET (endpoint=$DKA_S3_ENDPOINT)"
            aws s3 cp "$BACKUP_FILE" "$UPLOAD_TARGET/" --endpoint-url "$DKA_S3_ENDPOINT" --region "$DKA_S3_REGION"
            if [ $? -eq 0 ]; then
                echo "Upload successful."
            else
                echo "Upload failed."
            fi
        else
            echo "aws CLI not found in container. Install AWS CLI to enable S3/Wasabi uploads."
        fi
    fi
fi
