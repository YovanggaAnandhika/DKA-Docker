#!/bin/bash

# --- 1. Konfigurasi ---
DB_HOST=${DKA_DB_HOST:-localhost}
ROOT_USERNAME=${DKA_ROOT_USERNAME:-postgres}
ROOT_PASSWORD=${DKA_ROOT_PASSWORD:-postgres}

# Target DB yang akan di-backup
DB_NAME=${DKA_DB_NAME:-test}
# User pemilik DB (untuk referensi jika diperlukan)
DB_USER=${DKA_DB_USERNAME:-test}

BACKUP_DIR="/backup"
# Escape % dengan backslash untuk crontab
DATE=$(date +\%d-\%m-\%Y_\%H-\%M-\%S)
BACKUP_FILE="$BACKUP_DIR/${DB_NAME}_$DATE.sql.gz"

# Optional S3/Wasabi upload settings
DKA_S3_UPLOAD_ENABLE=${DKA_S3_UPLOAD_ENABLE:-false}
DKA_S3_BUCKET=${DKA_S3_BUCKET:-}
DKA_S3_PATH=${DKA_S3_PATH:-/}
DKA_S3_ENDPOINT=${DKA_S3_ENDPOINT:-https://s3.ap-southeast-1.wasabisys.com}
DKA_S3_REGION=${DKA_S3_REGION:-ap-southeast-1}

# Pastikan direktori backup ada
mkdir -p "$BACKUP_DIR"

# Ekspor password untuk sesi ini saja
export PGPASSWORD=$ROOT_PASSWORD

echo "----------------------------------------------------------"
echo "🚀 Memulai Backup Database: $DB_NAME"
echo "📅 Tanggal: $DATE"
echo "----------------------------------------------------------"

# --- 2. Proses Dump ---
pg_dump -h "$DB_HOST" -U "$ROOT_USERNAME" -d "$DB_NAME" \
    --no-owner \
    --no-privileges \
    --clean \
    --if-exists \
    --format=p \
    | gzip -9 > "$BACKUP_FILE"

# --- 3. Verifikasi ---
if [ ${PIPESTATUS[0]} -eq 0 ]; then
    FILE_SIZE=$(du -h "$BACKUP_FILE" | awk '{print $1}')
    echo "✅ Backup BERHASIL disimpan di: $BACKUP_FILE"
    echo "📊 Ukuran File: $FILE_SIZE"
else
    echo "❌ ERROR: Backup GAGAL!"
    # Hapus file jika korup (0 byte)
    rm -f "$BACKUP_FILE"
    exit 1
fi

# --- 4. Housekeeping (Opsional) ---
# Menghapus backup yang lebih lama dari 30 hari
find "$BACKUP_DIR" -name "*.sql.gz" -type f -mtime +30 -delete
echo "🧹 Housekeeping selesai (backup >30 hari dihapus)."
echo "----------------------------------------------------------"

# Jika upload diaktifkan, kirim file ke S3/Wasabi menggunakan aws CLI
if [ "$DKA_S3_UPLOAD_ENABLE" = "true" ]; then
    if [ -z "$DKA_S3_BUCKET" ]; then
        echo "S3 upload enabled but DKA_S3_BUCKET is not set. Skipping upload."
    else
        UPLOAD_TARGET="s3://$DKA_S3_BUCKET"
        if [ -n "$DKA_S3_PATH" ]; then
            UPLOAD_TARGET="$UPLOAD_TARGET/${DKA_S3_PATH#/}"
        fi

        if command -v aws >/dev/null 2>&1; then
            echo "Uploading $BACKUP_FILE -> $UPLOAD_TARGET (endpoint=$DKA_S3_ENDPOINT)"
            aws s3 cp "$BACKUP_FILE" "$UPLOAD_TARGET/" --endpoint-url "$DKA_S3_ENDPOINT" --region "$DKA_S3_REGION"
            if [ $? -eq 0 ]; then
                echo "Upload successful."
            else
                echo "Upload failed."
            fi
        else
            echo "aws CLI not found in container. Install AWS CLI to enable S3/Wasabi uploads."
        fi
    fi
fi

